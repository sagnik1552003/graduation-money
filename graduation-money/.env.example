# Local development only (run this on your machine).
VITE_LOCAL_MODEL_URL=http://localhost:11434/api/generate
VITE_LOCAL_MODEL_NAME=llama3.2

# Optional fallback for hosted deployments when the local model is unavailable.
VITE_GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# Vercel deploy: set these in Project Settings → Environment Variables.
# Point OLLAMA_BASE_URL to a publicly reachable Ollama endpoint (for example, via ngrok/cloudflare tunnel).
OLLAMA_BASE_URL=https://your-public-ollama-endpoint/api/generate
OLLAMA_MODEL=llama3.2

# If no model endpoint is available, the app falls back to a built-in letter template.
